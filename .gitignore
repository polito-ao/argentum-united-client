.godot/
*.import
export_presets.cfg

# Upscaled atlases live in Google Drive — too large to track. See CLAUDE.md.
assets/upscaled_2x/
assets/upscaled_2x.rar
assets/needs_upscale/

# Audio assets are generated locally from Cucsi via tools/convert_cucsi_audio.py
# (or downloaded from Google Drive). See assets/audio/README.md.
# Negate the README so the docs ship even though the audio doesn't.
# Also negate music_curated/ and sfx_curated/ — those are user-authored /
# hand-edited tracks + sound effects (originals, not derived from Cucsi),
# small enough to track in git.
assets/audio/*
!assets/audio/README.md
!assets/audio/music_curated/
!assets/audio/music_curated/**
!assets/audio/sfx_curated/
!assets/audio/sfx_curated/**

# fluidsynth soundfonts used by the audio conversion script.
# Bundled binary deps don't need to be checked in; tools/audio/README.md
# documents where to grab them.
tools/audio/TimGM6mb.sf2
tools/audio/FluidR3_GM.sf2

# Claude Code workspace state — local-only, never tracked.
.claude/
